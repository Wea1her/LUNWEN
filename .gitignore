# Ignore the virtual environment created for experiments

experiments/.venv/

# Ignore the __pycache__ directory created by Python in the experiments folder
experiments/__pycache__/


# Ignore the .codex directory created by the Codex extension for Visual Studio Code
.codex/

# Ignore the .claude directory created by the Claude extension for Visual Studio Code
.claude/

# Ignore the .articlewriting-skill directory created by the Article Writing Skill extension for Visual Studio Code
articlewriting-skill


.claude/CLAUDE.md
.codex/auth.json
.codex/config.toml

# Ignore LaTeX build artifacts for the journal paper
chapters/journal/*.aux
chapters/journal/*.bbl
chapters/journal/*.bcf
chapters/journal/*.blg
chapters/journal/*.fdb_latexmk
chapters/journal/*.fls
chapters/journal/*.loa
chapters/journal/*.lof
chapters/journal/*.log
chapters/journal/*.lot
chapters/journal/*.out
chapters/journal/*.run.xml
chapters/journal/*.synctex.gz
chapters/journal/*.synctex(busy)
chapters/journal/*.toc
chapters/journal/missfont.log
# Ignore dry-run experiment outputs
*dryrun*/

*results*/
